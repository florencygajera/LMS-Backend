# =============================================================================
# Agniveer Sentinel - Environment Configuration
# Copy this file to .env and update the values
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Agniveer Sentinel
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Security (IMPORTANT: Change these in production!)
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agniveer_db

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# S3/MinIO Storage Configuration
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=agniveer-documents
S3_REGION=us-east-1
S3_SECURE=False

# -----------------------------------------------------------------------------
# Weather API (Get your API key from https://openweathermap.org/api)
# -----------------------------------------------------------------------------
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# -----------------------------------------------------------------------------
# Email/SMTP Configuration
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Agniveer Sentinel <noreply@agniveer.mil.in>

# -----------------------------------------------------------------------------
# SMS Configuration (Optional - depends on your SMS provider)
# -----------------------------------------------------------------------------
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://sms.example.com/api

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# OCR Configuration (Optional - path to tesseract data)
# -----------------------------------------------------------------------------
TESSERACT_DATA_PATH=

# -----------------------------------------------------------------------------
# CORS Origins (comma-separated list)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT=60

# -----------------------------------------------------------------------------
# Backup Settings (Optional)
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=agniveer-backups
AWS_REGION=eu-west-1
BACKUP_DIR=/backups
LOG_DIR=/var/log/agniveer
UPLOAD_DIR=/uploads

# -----------------------------------------------------------------------------
# Vault Configuration (Optional - for secrets management)
# -----------------------------------------------------------------------------
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=your-vault-token

# -----------------------------------------------------------------------------
# Disaster Recovery (Optional)
# -----------------------------------------------------------------------------
DR_REGION=eu-central-1
DR_S3_BUCKET=agniveer-backups-dr
RDS_INSTANCE_ID=agniveer-db
